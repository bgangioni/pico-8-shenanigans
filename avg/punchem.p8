pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _init()

	debugger = {}

	counter = {0,0,0}
	pl = {
		x = 32,
		y = 72,
		z = 0,
		ymin = 28, 
		ymax = 95,
		xmin = 1,
		xmax = 111,
		speed = 2,
		xflipped = false,
		yflipped = false,
		state = "idle",
		jumpdelay = -10,
		maxjumpdelay = 10,
		sprite = {
			n = 0,
			w = 2,
			h = 4,
		},
		hitbox = {
			x1 = 2,
			y1 = 6,
			x2 = 11,
			y2 = 24,
		},
		punching = false,
		kicking = false,
		lives = 3,
		life = 0.67,
	}
end

function _update()
	counter[1] += 1
	if counter[2] > 0 then
		counter[2] -=1
		if counter[2] < 2 then pl.punching = false end
	end
	if counter[3] > 0 then counter[3] -=1 else pl.kicking = false end
	canwalk = (not(pl.state == "jumping")) and (not pl.punching)
	canslide = (not(pl.state == "jumping"))
	
	if btn(⬅️) then
		pl.xflipped = true
		if canwalk then pl.state = "walking" end
		if (pl.x > pl.xmin) then pl.x -= pl.speed end
	end
	if btn(➡️) then
		pl.xflipped = false
		if canwalk then pl.state = "walking" end
		if (pl.x < pl.xmax) then pl.x += pl.speed end
	end
	if btn(⬆️) then
		if canslide and pl.y > pl.ymin then pl.y -= pl.speed end
		if canwalk then pl.state = "walking" end
	end	
	if btn(⬇️) then
		if canslide and pl.y < pl.ymax then pl.y += pl.speed end
		if canwalk then pl.state = "walking" end
	end
	if btnp(4) and pl.jumpdelay == -pl.maxjumpdelay then
		pl.state = "jumping"
		pl.jumpdelay = pl.maxjumpdelay
	end
	if btnp(5) and counter[2] < 1 then
		if pl.state == "jumping" then
			pl. kicking = true
			counter[3] = 12
		else
			pl.punching = true
			counter[2] = 4 -- from highest to mid is hitting -> from mid to low (0) is cooldown
		end
	end
	if pl.state == "walking" then
		if pl.punching then
			pl.sprite.n = 8
		elseif counter [1] > 7 then
			counter [1] = 0
			pl.sprite.n += pl.sprite.w
			if pl.sprite.n > 4 then pl.sprite.n = 2 end
		end
		if not (btn(0) or btn(1) or btn(2) or btn(3)) then pl.state = "idle" end
	elseif pl.state == "jumping" then
			if pl.kicking then pl.sprite.n = 12 else pl.sprite.n = 6 end
			pl.z = pl.z-pl.jumpdelay
			pl.jumpdelay -= 1
		if (pl.jumpdelay < (-pl.maxjumpdelay)) then
			pl.state = "idle"
			pl.jumpdelay = -pl.maxjumpdelay
			pl.z = 0
		end
	else -- pl.state "idle"
		if pl.punching then pl.sprite.n = 8 else pl.sprite.n = 0 end
	end	
end	

function _draw()
	cls()
	map()
--	line(0,96,128,96,15)
	spr(pl.sprite.n,pl.x,pl.y+pl.z,pl.sprite.w,pl.sprite.h,pl.xflipped,pl.yflipped)

--draw debugger messages:
	for msg in all(debugger) do
		print (msg,9)
	end

--draw player hitbox:
--	rect(pl.x+pl.hitbox.x1,pl.y+pl.hitbox.y1,pl.x+pl.hitbox.x2,pl.y+pl.hitbox.y2,15)
end
