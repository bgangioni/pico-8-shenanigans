pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _init()
	p={
		x=0,
		y=0,
		s=0,
	}
	e={
		x=120,
		y=0,
		s=4,
	}
	bp=nil
	be=nil
end

function _update()
	if btn(0) then
		p.x-=1
	end
	if btn(1) then
		p.x+=1
	end
	if btn(2) then
		p.y-=1
	end
	if btn(3) then
		p.y+=1
	end
	if btn(4) then
		if bp==nil then
			bp={
				x=p.x,
				y=p.y,
				s=1,
			}
		end
	end
end

function _draw()
	cls(1)
	spr(p.s,p.x,p.y)
	spr(e.s,e.x,e.y)
	if bp then
		spr(bp.s,bp.x,bp.y)
	end
end
