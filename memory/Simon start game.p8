pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _init()
  escena=1
  timer=0
  boton=false
 end

function _update()
  timer+=1
  if escena==1 then
    if btnp(❎) then
      boton=true
    end
  elseif escena==2 then
    
  end
  
end

function _draw()
  cls(1)
  if escena==1 then
    spr(64,17,20,11,4)
    
    if timer%40 > 20 then
    		local texto="press x to start"
      print(texto,64-#(texto)*2,64,7)
    end
    if boton==true then
      cls(13) 
      spr(75,50,64,3,1)
    end
  end  
end
