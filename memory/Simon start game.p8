pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _init()
  escena=1
  timer=0
  boton=false
 end

function _update()
  timer+=1
  if escena==1 then
    if btnp(❎) then
      boton=true
    end
  elseif escena==2 then
    
  end
  
end

function _draw()
  cls(13)
  if escena==1 then
    spr(64,35,30,7,3)
    spr(71,0,112,2,2)
    spr(71,0,0,2,2,false,true)
    spr(71,112,0,2,2,true,true)
    spr(71,112,112,2,2,true,false)
    if timer%40 > 20 then
    		local texto="press x to start"
      print(texto,64-#(texto)*2,64,7)
    end
    if boton==true then
      cls(13) 
      spr(75,50,64,3,1)
    end
  end  
end
