pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _init()
	music(5)
	cont=0
	jug = {
		x = 4,
		y = 105,
		z=0,
		vel = 10,
		velz = -10,
		sprite = 0,
		caminando=false,
		pegando=false,
		atras=false,
	}
	
end

function _update()
	if jug.velz > -10 then  --- ARREGLAR ULTIMO -10
		jug.velz-=1
		jug.z-=jug.velz
	end
	sfx(0)
	if btn(⬅️)then
		jug.atras=true
		jug.caminando=true
		-- movimiento eje x
		if jug.x > 0 then
		jug.x-=1
		end
		-- animacion jug.sprite
		cont+=1
		if cont > jug.vel then
			cont=0
			jug.sprite+=1
			if jug.sprite > 1 then
				jug.sprite=0  
			end 
		end
	elseif btn(➡️)then
		jug.atras=false
		jug.caminando=true
		-- movimiento eje x
		if jug.x < 109 then
			jug.x+=1
		end
		-- animacion jug.sprite
		cont+=1 
		if cont > jug.vel then
			sfx(0)
			cont=0
			jug.sprite+=1
			if jug.sprite > 1 then
				jug.sprite=0
			end
		end
	else
		jug.caminando=false
	end
	if btn(⬆️)then
		jug.caminando=true
		-- movimiento eje y
		if jug.y > 80 then
			jug.y-=1
		end
		-- animacion jug.sprite
		cont+=1
		if cont > jug.vel then
			cont=0
			jug.sprite+=1
			if jug.sprite > 1 then
				jug.sprite=0  
			end 
		end
	end 
 
	if btn(⬇️)then
		jug.caminando=true
		-- movimiento eje y
		if jug.y < 105 then
			jug.y+=1
		end
		-- animacion jug.sprite
		cont+=1
		if cont > jug.vel then
			cont=0
			jug.sprite+=1
			if jug.sprite > 1 then
				jug.sprite=0  
			end 
		end
	end

	if btn(4)then
		jug.pegando=true
		sfx(1)
	else
		jug.pegando=false
	end

	if btn(5)then
		jug.velz=10
	end
	
end

function _draw()
 cls(13)
 map()
 if jug.pegando then
  spr(3,jug.x,jug.y+jug.z,3,2,jug.atras,false)
 elseif jug.caminando then
  spr(32+jug.sprite*3,jug.x,jug.y+jug.z,3,2,jug.atras,false)
 else
  spr(0,jug.x,jug.y+jug.z,3,2,jug.atras,false) 
 end
end
