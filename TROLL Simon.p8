pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _init()
 music(0,3,4)
 palt(0,false)
 cont=0
 vel=10
 troll=0
 camin=false
 pegar=false
 atras=false
 
end

function _update()
 if btn(⬅️)then
  atras=true
  cont+=1
  if cont > vel then
   cont=0
   troll+=1
    sfx(0)
   if troll > 1 then
   troll=0
   end 
  end
 else
  atras=false
 end
 if btn(➡️)then
  camin=true
  cont+=1
  if cont > vel then
   cont=0
   troll+=1
    sfx(0) 
   if troll > 1 then
   troll=0
   end
  end
 else
  camin=false
 end
 if btn(❎)then
  pegar=true
  sfx(1)
 else
  pegar=false 
 end
end
 

function _draw()
 cls(15)
 if pegar then
  spr(3,4,112,3,2)
 elseif camin then
  spr(32+troll*3,4,112,3,2)
 elseif atras then
  spr(6+troll*3,4,112,3,2)
 else
  spr(0,4,112,3,2) 
 end
end 
 

